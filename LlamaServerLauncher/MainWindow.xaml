<Window x:Class="LlamaServerLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LlamaServerLauncher"
        xmlns:vm="clr-namespace:LlamaServerLauncher.ViewModels"
        mc:Ignorable="d"
        Title="llama-server launcher" Height="650" Width="900"
        MinHeight="500" MinWidth="770"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Server Control -->
        <GroupBox Grid.Row="0" Header="Server Control" Margin="5,5,5,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                    <Button Content="Start Server" Command="{Binding StartServerCommand}" 
                            IsEnabled="{Binding CanStartServer}" Width="120" Height="35"/>
                    <Button Content="Stop Server" Command="{Binding StopServerCommand}" 
                            IsEnabled="{Binding IsServerRunning}" Width="120" Height="35"/>
                    <Button Content="Unload Model" Command="{Binding UnloadModelCommand}" 
                            IsEnabled="{Binding IsServerRunning}" Width="120" Height="35"/>
                </StackPanel>

                <TextBlock Text="{Binding ServerStatus}" 
                            HorizontalAlignment="Center" Margin="5" FontWeight="Bold"/>

                <Border Background="#2D2D30" CornerRadius="3" Padding="8" Margin="5">
                    <TextBlock Text="{Binding CurrentCommand}" 
                               FontFamily="Consolas" FontSize="11"
                               Foreground="#9CDCFE" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </GroupBox>

        <!-- TabControl -->
        <TabControl Grid.Row="1">
            
            <!-- Tab 1: Profiles (first) -->
            <TabItem Header="Profiles">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <!-- Profiles -->
                        <GroupBox Header="Profiles">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Label Grid.Column="0" Content="Profile:" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding Profiles}" 
                                        SelectedItem="{Binding SelectedProfile}" 
                                        Text="{Binding ProfileNameInput, UpdateSourceTrigger=PropertyChanged}"
                                        IsEditable="True" MinWidth="150" Margin="3"/>
                                <Button Grid.Column="2" Content="Save" Command="{Binding SaveProfileCommand}" 
                                        VerticalAlignment="Center"/>
                                <Button Grid.Column="3" Content="Load" Command="{Binding LoadProfileCommand}" 
                                        VerticalAlignment="Center"/>
                                <Button Grid.Column="4" Content="Delete" Command="{Binding DeleteProfileCommand}" 
                                        VerticalAlignment="Center"/>
                                <Button Grid.Column="5" Content="Export" Command="{Binding ExportProfileCommand}" 
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </GroupBox>

 
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Tab 2: Main -->
            <TabItem Header="Main">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <!-- Paths -->
                        <GroupBox Header="Paths">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="llama-server.exe:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ExecutablePath, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource WideTextBox}" VerticalAlignment="Center"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="Browse..." Command="{Binding BrowseExecutableCommand}" 
                                        VerticalAlignment="Center"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="Model (-m):" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ModelPath, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource WideTextBox}" VerticalAlignment="Center"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="Browse..." Command="{Binding BrowseModelCommand}" 
                                        VerticalAlignment="Center"/>

                                <Label Grid.Row="2" Grid.Column="0" Content="Models Dir (--models-dir):" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ModelsDir, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource WideTextBox}" VerticalAlignment="Center"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="Browse..." Command="{Binding BrowseModelsDirCommand}" 
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </GroupBox>

                        <!-- Network Settings -->
                        <GroupBox Header="Network Settings">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Label Grid.Column="0" Content="Host:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource NarrowTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <Label Grid.Column="2" Content="Port:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="3" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource NarrowTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Tab 3: Generation -->
            <TabItem Header="Generation">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <!-- Model Parameters -->
                        <GroupBox Header="Model Parameters">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Label Grid.Column="0" Content="Context Size:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding ContextSize, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource NarrowTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <Label Grid.Column="2" Content="Threads:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="3" Text="{Binding Threads, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource NarrowTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <Label Grid.Column="4" Content="GPU Layers:" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="5" Text="{Binding GpuLayers, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource NarrowTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </Grid>
                        </GroupBox>

                        <!-- Generation Parameters -->
                        <GroupBox Header="Generation Parameters">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="Temperature:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Temperature, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource NarrowTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <Label Grid.Row="0" Grid.Column="2" Content="Max Tokens:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding MaxTokens, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource NarrowTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <Label Grid.Row="0" Grid.Column="4" Content="Batch Size:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding BatchSize, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource NarrowTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="Top-K:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TopK, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource NarrowTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <Label Grid.Row="1" Grid.Column="2" Content="Top-P:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding TopP, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource NarrowTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <Label Grid.Row="1" Grid.Column="4" Content="Repeat Penalty:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding RepeatPenalty, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource NarrowTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Tab 4: Options -->
            <TabItem Header="Options">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <!-- Additional Options -->
                        <GroupBox Header="Additional Options">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Row="0" Grid.Column="0" Content="Flash Attention" IsThreeState="True" 
                                        IsChecked="{Binding FlashAttention}" Margin="10,3"/>
                                <CheckBox Grid.Row="0" Grid.Column="1" Content="WebUI" IsThreeState="True" 
                                        IsChecked="{Binding EnableWebUI}" Margin="10,3"/>
                                <CheckBox Grid.Row="0" Grid.Column="2" Content="Embedding" IsThreeState="True" 
                                        IsChecked="{Binding EmbeddingMode}" Margin="10,3"/>
                                <CheckBox Grid.Row="0" Grid.Column="3" Content="Slots" IsThreeState="True" 
                                        IsChecked="{Binding EnableSlots}" Margin="10,3"/>
                                <CheckBox Grid.Row="0" Grid.Column="4" Content="Metrics" IsThreeState="True" 
                                        IsChecked="{Binding EnableMetrics}" Margin="10,3"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="API Key:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" 
                                        Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource WideTextBox}" VerticalAlignment="Center"/>

                                <Label Grid.Row="2" Grid.Column="0" Content="Log File:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" 
                                        Text="{Binding LogFilePath, UpdateSourceTrigger=PropertyChanged}" 
                                        Style="{StaticResource WideTextBox}" VerticalAlignment="Center"/>
                                <Button Grid.Row="2" Grid.Column="3" Content="Browse..." Command="{Binding BrowseLogFileCommand}" 
                                        VerticalAlignment="Center"/>

                                <CheckBox Grid.Row="1" Grid.Column="3" Content="Verbose Logging" 
                                        IsChecked="{Binding VerboseLogging}" Margin="10,3"/>
                            </Grid>
                        </GroupBox>

                        <!-- Custom Arguments -->
                        <GroupBox Header="Custom Arguments">
                            <TextBox Text="{Binding CustomArguments, UpdateSourceTrigger=PropertyChanged}" 
                                    AcceptsReturn="True" TextWrapping="Wrap" Height="60"
                                    VerticalScrollBarVisibility="Auto"/>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Панель лога - всегда видна внизу -->
        <GroupBox Grid.Row="2" Header="Server Log" Margin="5,0,5,5">
            <Grid>
                <TextBox x:Name="LogTextBox"
                         Text="{Binding LogText, Mode=OneWay}"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontSize="11"
                         Background="#1E1E1E"
                         Foreground="#DCDCDC"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         MaxHeight="200"/>
                <Button Content="Clear Log" 
                        Command="{Binding ClearLogCommand}"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top" 
                        Margin="5"/>
            </Grid>
        </GroupBox>
    </Grid>
</Window>